<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Wanderlust</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Leaflet -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>

  <style>
    body { background-color: #f8f9fa; }

    .gallery-img {
      height: 400px;
      object-fit: cover;
    }

    .star {
      font-size: 25px;
      color: gray;
      cursor: pointer;
    }

    .star.selected {
      color: gold;
    }
  </style>
</head>

<body>

<%- include("../partials/navbar") %>

<div class="container mt-5">

  <!-- ❤️ WISHLIST -->
  <% if(currUser){ %>
    <form method="POST" action="/listings/<%= listing._id %>/wishlist">
      <button class="btn btn-outline-danger mb-3">
        ❤️ Add / Remove Wishlist
      </button>
    </form>
  <% } %>

  <div class="card shadow-lg rounded-4 overflow-hidden">

    <!-- 🖼️ IMAGE GALLERY -->
    <div id="carouselExample" class="carousel slide">
      <div class="carousel-inner">

        <% if(listing.images && listing.images.length > 0){ %>

          <% listing.images.forEach((img, i) => { %>
            <div class="carousel-item <%= i===0 ? 'active' : '' %>">
              <img src="<%= img.url %>" class="d-block w-100 gallery-img">
            </div>
          <% }) %>

        <% } else { %>
          <div class="carousel-item active">
            <img src="https://via.placeholder.com/800x400" class="d-block w-100 gallery-img">
          </div>
        <% } %>

      </div>

      <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
      </button>

      <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
      </button>
    </div>

    <div class="card-body">

      <h2 class="fw-bold"><%= listing.title %></h2>

      <p class="text-muted"><%= listing.description %></p>

      <h4 class="text-success">
        ₹ <%= listing.price.toLocaleString("en-IN") %>
      </h4>

      <p>
        📍 <%= listing.location %>, <%= listing.country %>
      </p>

      <!-- OWNER BUTTONS -->
      <% if(currUser && listing.owner && currUser._id.equals(listing.owner._id)) { %>

        <a href="/listings/<%= listing._id %>/edit" class="btn btn-warning">
          ✏️ Edit
        </a>

        <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE" style="display:inline;">
          <button class="btn btn-danger">🗑️ Delete</button>
        </form>

      <% } %>

      <!-- ⭐ AVERAGE -->
      <hr>

      <%
        let avg = 0;
        if(listing.reviews.length > 0){
          let sum = 0;
          listing.reviews.forEach(r => sum += r.rating);
          avg = (sum / listing.reviews.length).toFixed(1);
        }
      %>

      <h5>⭐ Average Rating: <%= avg %></h5>

      <!-- ADD REVIEW -->
      <hr>

      <h4>Add Review</h4>

      <form method="POST" action="/listings/<%= listing._id %>/reviews">

        <div class="mb-3">
          <span class="star" data-value="1">★</span>
          <span class="star" data-value="2">★</span>
          <span class="star" data-value="3">★</span>
          <span class="star" data-value="4">★</span>
          <span class="star" data-value="5">★</span>

          <input type="hidden" name="review[rating]" id="ratingInput" required>
        </div>

        <textarea name="review[comment]" class="form-control mb-2" required></textarea>

        <button class="btn btn-primary">Submit</button>

      </form>

      <!-- REVIEWS -->
      <hr>

      <h4>All Reviews</h4>

      <% if(listing.reviews.length > 0){ %>

        <% listing.reviews.forEach(review => { %>

          <div class="card p-3 mb-3">

            <p>
              <% for(let i=1;i<=5;i++){ %>
                <%= i<=review.rating ? "⭐" : "☆" %>
              <% } %>
            </p>

            <p><%= review.comment %></p>

            <% if(currUser && review.author && currUser._id.equals(review.author._id)){ %>
              <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                <button class="btn btn-danger btn-sm">Delete</button>
              </form>
            <% } %>

          </div>

        <% }) %>

      <% } else { %>

        <p>No reviews yet</p>

      <% } %>

    </div>
  </div>
</div>

<!-- 🗺️ MAP -->
<div class="container mt-4">
  <h4>Location Map</h4>
  <div id="map" style="height:400px;"></div>
</div>

<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<script>
  const coordinates = <%- JSON.stringify(listing.geometry?.coordinates || [77.2090, 28.6139]) %>;

  const map = L.map('map').setView([coordinates[1], coordinates[0]], 10);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

  L.marker([coordinates[1], coordinates[0]])
    .addTo(map)
    .bindPopup("<b><%= listing.title %></b>")
    .openPopup();
</script>

<!-- ⭐ STAR -->
<script>
  const stars = document.querySelectorAll(".star");
  const ratingInput = document.getElementById("ratingInput");

  stars.forEach(star => {
    star.addEventListener("click", () => {
      let value = star.getAttribute("data-value");
      ratingInput.value = value;

      stars.forEach(s => s.classList.remove("selected"));

      for (let i = 0; i < value; i++) {
        stars[i].classList.add("selected");
      }
    });
  });
</script>

</body>
</html>
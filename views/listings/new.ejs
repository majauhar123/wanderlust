<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>WanderLust</title>

    <link rel="stylesheet" href="/css/style.css">
    
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
      body {
        background: #f8f9fa;
      }

      .form-container {
        max-width: 700px;
        margin: auto;
      }
    </style>
  </head>

  <body>

    <!-- Navbar -->
    <%- include("../partials/navbar") %>

    <div class="container mt-5 form-container">

      <h2 class="text-center mb-4">Create a New Listing</h2>

      <!-- FORM -->
      <form method="POST" 
            action="/listings" 
            enctype="multipart/form-data"
            class="shadow p-4 rounded bg-light">

        <!-- Title -->
        <div class="mb-3">
          <label class="form-label fw-bold">Title</label>
          <input name="listing[title]" 
                 class="form-control" 
                 placeholder="Enter title"
                 required />
        </div>

        <!-- Description -->
        <div class="mb-3">
          <label class="form-label fw-bold">Description</label>
          <textarea name="listing[description]" 
                    class="form-control" 
                    rows="3"
                    placeholder="Enter description"></textarea>
        </div>

        <!-- IMAGE UPLOAD -->
        <div class="mb-3">
          <label class="form-label fw-bold">Upload Image</label>
          <input type="file" 
                 name="listing[image]" 
                 class="form-control"
                 accept="image/*"
                 required />
        </div>

        <!-- Price -->
        <div class="mb-3">
          <label class="form-label fw-bold">Price</label>
          <input name="listing[price]" 
                 type="number" 
                 class="form-control" 
                 placeholder="Enter price"
                 required />
        </div>

        <!-- Country -->
        <div class="mb-3">
          <label class="form-label fw-bold">Country</label>
          <input name="listing[country]" 
                 class="form-control" 
                 placeholder="Enter country"
                 required />
        </div>

        <!-- Location -->
        <div class="mb-3">
          <label class="form-label fw-bold">Location</label>
          <input name="listing[location]" 
                 class="form-control" 
                 placeholder="Enter location"
                 required />
        </div>

        <!-- Category -->
        <div class="mb-3">
          <label class="form-label fw-bold">Category</label>
          <select name="listing[category]" class="form-select">
            <option value="Beach">🏖 Beach</option>
            <option value="Mountain">⛰ Mountain</option>
            <option value="City">🏙 City</option>
            <option value="Farm">🌾 Farm</option>
          </select>
        </div>

        <!-- Submit Button -->
        <button class="btn btn-dark w-100 fw-bold">
          ➕ Add Listing
        </button>

      </form>

    </div>

  </body>
</html>
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>WanderLust</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
      body {
        background-color: #f8f9fa;
      }

      .card:hover {
        transform: scale(1.03);
        transition: 0.3s;
      }
    </style>
  </head>

  <body>

    <!-- Navbar -->
    <%- include("../partials/navbar") %>

    <!-- ⭐ FLASH MESSAGE -->
    <div class="container mt-3">
      <%- include("../partials/flash") %>
    </div>

    <div class="container mt-4">

      <!-- Heading + Button -->
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">All Listings</h2>

        <a href="/listings/new" class="btn btn-dark">
          + Create New Listing
        </a>
      </div>

      <!-- ⭐ CATEGORY FILTER -->
      <div class="mb-4 text-center">

        <a href="/listings" class="btn btn-outline-dark m-1">All</a>
        <a href="/listings?category=Beach" class="btn btn-primary m-1">🏖 Beach</a>
        <a href="/listings?category=Mountain" class="btn btn-success m-1">⛰ Mountain</a>
        <a href="/listings?category=City" class="btn btn-warning m-1">🏙 City</a>
        <a href="/listings?category=Farm" class="btn btn-info m-1">🌾 Farm</a>

      </div>

      <!-- ⭐ CARDS -->
      <div class="row">

        <% if(allListings.length > 0) { %>

          <% for(let listing of allListings) { %>

            <div class="col-md-4 mb-4">
              <div class="card shadow-sm h-100 rounded-4 overflow-hidden">

                <!-- Image -->
                <img src="<%= listing.image %>" 
                     class="card-img-top"
                     style="height:220px; object-fit:cover;" />

                <div class="card-body">

                  <!-- Title -->
                  <h5 class="card-title fw-bold">
                    <%= listing.title %>
                  </h5>

                  <!-- Location -->
                  <p class="text-muted mb-1">
                    📍 <%= listing.location %>, <%= listing.country %>
                  </p>

                  <!-- Price -->
                  <h6 class="text-success fw-bold">
                    ₹ <%= listing.price.toLocaleString("en-IN") %>
                  </h6>

                  <!-- Button -->
                  <a href="/listings/<%= listing._id %>" 
                     class="btn btn-dark w-100 mt-2">
                    View Details
                  </a>

                </div>

              </div>
            </div>

          <% } %>

        <% } else { %>

          <h4 class="text-center text-muted">No listings found 😔</h4>

        <% } %>

      </div>

    </div>

  </body>
</html>
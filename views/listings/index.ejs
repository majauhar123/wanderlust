<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>WanderLust</title>

  <link rel="stylesheet" href="/css/style.css">

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body { background: #f8f9fa; }

    /* HERO */
    .hero {
      position: relative;
      height: 90vh;
      background: url("https://images.unsplash.com/photo-1501785888041-af3ef285b470") center/cover no-repeat;
      display: flex;
      align-items: center;
      justify-content: center;
      border-bottom-left-radius: 40px;
      border-bottom-right-radius: 40px;
      overflow: hidden;
    }

    .hero-overlay {
      position: absolute;
      width: 100%;
      height: 100%;
      background: rgba(0,0,0,0.4);
    }

    .hero-content {
      position: relative;
      z-index: 2;
    }

    .hero h1 {
      font-size: 48px;
      font-weight: bold;
    }

    .hero p {
      font-size: 18px;
      color: #eee;
    }

    .search-box-hero {
      background: white;
      border-radius: 50px;
      padding: 10px;
      display: flex;
      max-width: 600px;
      margin: auto;
      box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    .search-box-hero input {
      border: none;
      outline: none;
      flex: 1;
      padding-left: 15px;
    }

    .search-box-hero button {
      border-radius: 50px;
      padding: 8px 20px;
    }

    /* CARDS */
    .card {
      border-radius: 16px;
      overflow: hidden;
    }

    .card:hover {
      transform: scale(1.03);
      transition: 0.3s;
      cursor: pointer;
    }
  </style>
</head>

<body>

<%- include("../partials/navbar") %>

<!-- HERO SECTION -->
<section class="hero">

  <div class="hero-overlay"></div>

  <div class="hero-content text-center text-white">

    <h1>Let’s Explore the World 🌍</h1>
    <p>Find amazing places to stay and travel</p>

    <!-- SEARCH -->
    <form method="GET" action="/listings" class="search-box-hero mt-4">
      <input type="text" name="search" placeholder="Search destination..." />
      <button class="btn btn-dark">Search</button>
    </form>

  </div>

</section>

<!-- FLASH -->
<div class="container mt-4">
  <%- include("../partials/flash") %>
</div>

<!-- LISTINGS -->
<div class="container mt-5">

  <h3 class="mb-4 fw-bold">Featured Destinations ✨</h3>

  <div class="row">

    <% if(allListings.length > 0){ %>

      <% for(let listing of allListings){ %>

        <div class="col-md-4 mb-4">
          <div class="card shadow-sm h-100"
               onclick="window.location='/listings/<%= listing._id %>'">

            <img 
              src="<%= 
                (listing.image && listing.image.url) 
                || listing.image 
                || 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e'
              %>" 
              class="card-img-top"
              style="height:220px; object-fit:cover;" 
            />

            <div class="card-body">
              <h5 class="fw-bold"><%= listing.title %></h5>

              <p class="text-muted mb-1">
                📍 <%= listing.location %>, <%= listing.country %>
              </p>

              <h6 class="text-success fw-bold">
                ₹ <%= listing.price.toLocaleString("en-IN") %>
              </h6>
            </div>

          </div>
        </div>

      <% } %>

    <% } else { %>

      <h4 class="text-center text-muted">No listings found 😔</h4>

    <% } %>

  </div>

</div>

</body>
</html>
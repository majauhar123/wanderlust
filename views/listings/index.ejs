<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>WanderLust</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Leaflet -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>

  <!-- Marker Cluster -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster/dist/MarkerCluster.css"/>
  <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster/dist/MarkerCluster.Default.css"/>

  <style>
    body { background: #f8f9fa; }

    #map {
      height: 400px;
      border-radius: 12px;
      margin-bottom: 20px;
    }

    .card:hover {
      transform: scale(1.03);
      transition: 0.3s;
      cursor: pointer;
    }
  </style>
</head>

<body>

<%- include("../partials/navbar") %>

<div class="container mt-3">
  <%- include("../partials/flash") %>
</div>

<div class="container mt-4">

  <!-- SEARCH -->
  <form method="GET" action="/listings" class="mb-4 d-flex">
    <input 
      type="text" 
      name="search" 
      class="form-control me-2"
      placeholder="Search location, country..."
    />
    <button class="btn btn-dark">Search</button>
  </form>

  <!-- MAP -->
  <h4 class="text-center mb-3">Explore Places 🌍</h4>
  <div id="map"></div>

  <!-- CARDS -->
  <div class="row">

    <% if(allListings.length > 0){ %>

      <% for(let listing of allListings){ %>

        <div class="col-md-4 mb-4">
          <div class="card shadow-sm h-100"
               onclick="window.location='/listings/<%= listing._id %>'">

            <!-- ✅ SAFE IMAGE -->
            <img 
              src="<%= listing.image?.url || listing.image || 'https://via.placeholder.com/400' %>" 
              class="card-img-top"
              style="height:220px; object-fit:cover;" 
            />

            <div class="card-body">
              <h5 class="fw-bold"><%= listing.title %></h5>

              <p class="text-muted mb-1">
                📍 <%= listing.location %>, <%= listing.country %>
              </p>

              <h6 class="text-success fw-bold">
                ₹ <%= listing.price.toLocaleString("en-IN") %>
              </h6>
            </div>

          </div>
        </div>

      <% } %>

    <% } else { %>

      <h4 class="text-center text-muted">No listings found 😔</h4>

    <% } %>

  </div>

</div>

<!-- Leaflet JS -->
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<!-- Marker Cluster JS -->
<script src="https://unpkg.com/leaflet.markercluster/dist/leaflet.markercluster.js"></script>

<script>
  // ✅ SAFE JSON (IMPORTANT)
  const listings = <%- JSON.stringify(allListings || []) %>;

  const map = L.map('map').setView([28.6139, 77.2090], 5);

  // TILE FIRST
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap contributors'
  }).addTo(map);

  const markers = L.markerClusterGroup();
  let bounds = [];

  listings.forEach(listing => {
    if(listing.geometry && listing.geometry.coordinates){

      const coords = listing.geometry.coordinates;

      const marker = L.marker([coords[1], coords[0]]);

      marker.bindPopup(`
        <div style="text-align:center;">
          <b>${listing.title}</b><br>
          📍 ${listing.location}<br>
          <a href="/listings/${listing._id}" class="btn btn-sm btn-dark mt-1">View</a>
        </div>
      `);

      markers.addLayer(marker);
      bounds.push([coords[1], coords[0]]);
    }
  });

  map.addLayer(markers);

  if(bounds.length > 0){
    map.fitBounds(bounds, { padding: [50, 50] });
  }

  // ✅ MAP FIX (VERY IMPORTANT 🔥)
  setTimeout(() => {
    map.invalidateSize();
  }, 500);

  // USER LOCATION
  if(navigator.geolocation){
    navigator.geolocation.getCurrentPosition(position => {
      const lat = position.coords.latitude;
      const lng = position.coords.longitude;

      L.marker([lat, lng])
        .addTo(map)
        .bindPopup("📍 You are here");
    });
  }
</script>

</body>
</html>
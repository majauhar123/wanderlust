<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Wanderlust</title>

  <link rel="stylesheet" href="/css/style.css">

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      font-family: sans-serif;
      background: #f8f9fa;
    }

    .hero {
      height: 100vh;
      background: url("https://images.unsplash.com/photo-1501785888041-af3ef285b470") center/cover no-repeat;
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .hero::before {
      content: "";
      position: absolute;
      width: 100%;
      height: 100%;
      background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.8));
    }

    .hero-navbar {
      position: fixed;
      top: 20px;
      left: 50%;
      transform: translateX(-50%);
      width: 90%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 30px;
      border-radius: 50px;
      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(10px);
      z-index: 1000;
    }

    .hero-navbar a {
      color: white;
      text-decoration: none;
      margin: 0 12px;
    }

    .left {
      color: white;
      font-size: 22px;
      font-weight: bold;
    }

    .signup-btn {
      background: orange;
      padding: 6px 15px;
      border-radius: 20px;
      color: white;
    }

    .hero-content {
      text-align: center;
      color: white;
      z-index: 2;
    }

    .search-box {
      margin-top: 40px;
      background: white;
      border-radius: 50px;
      padding: 10px;
      display: flex;
      gap: 10px;
      width: 80%;
      max-width: 650px;
    }

    section {
      padding: 80px 0;
      opacity: 0;
      transform: translateY(50px);
      transition: 0.6s;
    }

    .card:hover {
      transform: translateY(-10px);
      transition: 0.3s;
    }
  </style>
</head>

<body>

<!-- NAVBAR -->
<div class="hero-navbar">
  <div class="left">🌍 Wanderlust</div>

  <div>
    <a href="#">Home</a>
    <a href="#destination">Destination</a>
    <a href="#features">Features</a>
    <a href="#pricing">Pricing</a>
  </div>

  <div>
    <a href="/login">Sign in</a>
    <a href="/signup" class="signup-btn">Sign up</a>
  </div>
</div>

<!-- HERO -->
<div class="hero">
  <div class="hero-content">

    <h1>Explore World 🌍</h1>

    <button class="btn btn-warning mt-3" onclick="location.href='/listings'">
      Explore Now
    </button>

    <form action="/listings" method="GET" class="search-box">
      <input type="text" name="search" placeholder="Search destination..." />
      <button class="btn btn-dark">Search</button>
    </form>

  </div>
</div>

<!-- 🔥 DYNAMIC LISTINGS -->
<section id="destination" class="container text-center">
  <h2 class="fw-bold mb-5">Explore Listings ✈️</h2>

  <div class="row g-4">

    <% if(listings && listings.length > 0){ %>

      <% listings.forEach(listing => { %>

        <div class="col-md-4">
          <div class="card shadow h-100"
               onclick="window.location='/listings/<%= listing._id %>'">

            <img 
              src="<%= (listing.image && listing.image.url) || listing.image %>" 
              style="height:200px; object-fit:cover;"
            >

            <div class="card-body">
              <h5><%= listing.title %></h5>
              <p>₹ <%= listing.price %></p>
              <p class="text-muted"><%= listing.location %></p>
            </div>

          </div>
        </div>

      <% }) %>

    <% } else { %>

      <h5>No listings found 😔</h5>

    <% } %>

  </div>
</section>

<!-- FEATURES -->
<section id="features" class="container text-center bg-light">
  <h2 class="fw-bold mb-5">Why Choose Us ⭐</h2>

  <div class="row">
    <div class="col-md-4">🌍 Explore</div>
    <div class="col-md-4">💸 Affordable</div>
    <div class="col-md-4">🔒 Secure</div>
  </div>
</section>

<!-- PRICING -->
<section id="pricing" class="container text-center">
  <h2 class="fw-bold mb-5">Pricing 💰</h2>

  <div class="row">
    <div class="col-md-4"><div class="card p-4 shadow">₹999</div></div>
    <div class="col-md-4"><div class="card p-4 shadow border-primary">₹1999</div></div>
    <div class="col-md-4"><div class="card p-4 shadow">₹4999</div></div>
  </div>
</section>

<!-- ANIMATION -->
<script>
  const sections = document.querySelectorAll("section");

  window.addEventListener("scroll", () => {
    sections.forEach(sec => {
      const offset = sec.offsetTop - 300;
      if(window.scrollY > offset){
        sec.style.opacity = "1";
        sec.style.transform = "translateY(0)";
      }
    });
  });
</script>

</body>
</html>
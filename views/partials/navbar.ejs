<nav class="navbar navbar-expand-lg navbar-dark fixed-top custom-navbar">

  <div class="container">

    <!-- LOGO -->
    <a class="navbar-brand fw-bold fs-4" href="/listings">
      🌍 Wanderlust
    </a>

    <!-- TOGGLE -->
    <button 
      class="navbar-toggler" 
      type="button" 
      data-bs-toggle="collapse" 
      data-bs-target="#navbarNav"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- MENU -->
    <div class="collapse navbar-collapse" id="navbarNav">

      <!-- 🔍 SEARCH -->
      <form class="d-flex mx-auto my-2 my-lg-0 search-box" action="/listings" method="GET">
        <input 
          class="form-control me-2 rounded-pill shadow-sm" 
          type="search" 
          name="search"
          placeholder="Search destinations..."
        />
        <button class="btn btn-light rounded-pill px-3 fw-bold">Search</button>
      </form>

      <!-- RIGHT -->
      <div class="ms-auto d-flex align-items-center gap-2 mt-3 mt-lg-0">

        <% if(!currUser) { %>

          <a href="/login" class="btn btn-outline-light rounded-pill px-3">
            Login
          </a>

          <a href="/signup" class="btn btn-warning rounded-pill px-3 fw-bold">
            Signup
          </a>

        <% } else { %>

          <a href="/wishlist" class="btn btn-outline-danger rounded-pill px-3">
            ❤️ Wishlist
          </a>

          <a href="/profile" class="btn btn-outline-info rounded-pill px-3">
            👤 <%= currUser.username %>
          </a>

          <a href="/logout" class="btn btn-danger rounded-pill px-3">
            Logout
          </a>

        <% } %>

      </div>

    </div>

  </div>

</nav>

<!-- SPACING FIX (IMPORTANT) -->
<div style="height: 90px;"></div>

<!-- BOOTSTRAP JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
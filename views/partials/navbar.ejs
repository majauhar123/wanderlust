<nav class="navbar navbar-expand-lg navbar-dark bg-dark px-4 shadow-sm">

  <!-- Logo -->
  <a class="navbar-brand fw-bold" href="/listings">🌍 Wanderlust</a>

  <!-- Toggle -->
  <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
    <span class="navbar-toggler-icon"></span>
  </button>

  <div class="collapse navbar-collapse" id="navbarNav">

    <!-- 🔍 SEARCH -->
    <form class="d-flex mx-auto" action="/listings" method="GET" style="width: 40%;">
      <input 
        class="form-control me-2" 
        type="search" 
        name="search"
        placeholder="Search location..."
      />
      <button class="btn btn-outline-light">Search</button>
    </form>

    <!-- RIGHT SIDE -->
    <div class="ms-auto d-flex align-items-center">

      <% if(!currUser) { %>

        <a href="/login" class="btn btn-outline-light me-2">Login</a>
        <a href="/signup" class="btn btn-warning">Signup</a>

      <% } else { %>

        <!-- ❤️ WISHLIST -->
        <a href="/wishlist" class="btn btn-outline-danger me-2">
          ❤️ Wishlist
        </a>

        <!-- 👤 PROFILE -->
        <a href="/profile" class="btn btn-outline-info me-2">
          👤 <%= currUser.username %>
        </a>

        <!-- LOGOUT -->
        <a href="/logout" class="btn btn-danger">Logout</a>

      <% } %>

    </div>

  </div>
</nav>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Wanderlust</title>

  <link rel="stylesheet" href="/css/style.css">

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      font-family: 'Poppins', sans-serif;
      background: #f8f9fa;
    }

    /* HERO */
    .hero {
      height: 100vh;
      background: url("https://images.unsplash.com/photo-1501785888041-af3ef285b470") center/cover no-repeat;
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .hero::before {
      content: "";
      position: absolute;
      width: 100%;
      height: 100%;
      background: rgba(0,0,0,0.4);
    }

    .hero-content {
      text-align: center;
      color: white;
      z-index: 2;
    }

    .hero-content h1 {
      font-size: 48px;
      font-weight: bold;
    }

    .explore-btn {
      background: orange;
      border: none;
      padding: 10px 25px;
      border-radius: 20px;
      margin-top: 20px;
      color: white;
      font-weight: bold;
    }

    /* SEARCH */
    .search-box {
      margin-top: 30px;
      background: white;
      border-radius: 50px;
      padding: 10px;
      display: flex;
      gap: 10px;
      width: 80%;
      max-width: 650px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.3);
    }

    .search-box input {
      border: none;
      outline: none;
      flex: 1;
    }

    /* SECTIONS */
    section {
      padding: 80px 0;
      opacity: 0;
      transform: translateY(50px);
      transition: 0.6s;
    }

    /* CARD */
    .card {
      border-radius: 15px;
      overflow: hidden;
    }

    .card:hover {
      transform: translateY(-10px);
      transition: 0.3s;
      cursor: pointer;
    }
  </style>
</head>

<body>

<!-- ✅ GLOBAL NAVBAR -->
<%- include("../partials/navbar") %>

<!-- HERO -->
<div class="hero">
  <div class="hero-content">

    <h1>Let’s Explore the World 🌍</h1>

    <button class="explore-btn" onclick="location.href='/listings'">
      Explore Now
    </button>

    <form action="/listings" method="GET" class="search-box">
      <input type="text" name="search" placeholder="Search destination..." />
      <button class="btn btn-dark rounded-pill px-3">Search</button>
    </form>

  </div>
</div>

<!-- LISTINGS -->
<section id="destination" class="container text-center">
  <h2 class="fw-bold mb-5">Explore Listings ✈️</h2>

  <div class="row g-4">

    <% if(listings && listings.length > 0){ %>

      <% listings.forEach(listing => { %>

        <div class="col-md-4">
          <div class="card shadow h-100"
               onclick="window.location='/listings/<%= listing._id %>'">

            <img 
              src="<%= (listing.image && listing.image.url) || listing.image || 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e' %>" 
              style="height:200px; object-fit:cover;"
            >

            <div class="card-body">
              <h5 class="fw-bold"><%= listing.title %></h5>
              <p class="text-success fw-bold">₹ <%= listing.price %></p>
              <p class="text-muted"><%= listing.location %></p>
            </div>

          </div>
        </div>

      <% }) %>

    <% } else { %>

      <h5>No listings found 😔</h5>

    <% } %>

  </div>
</section>

<!-- FEATURES -->
<section id="features" class="container text-center bg-light">
  <h2 class="fw-bold mb-5">Why Choose Us ⭐</h2>

  <div class="row">
    <div class="col-md-4">🌍 Explore</div>
    <div class="col-md-4">💸 Affordable</div>
    <div class="col-md-4">🔒 Secure</div>
  </div>
</section>

<!-- PRICING -->
<section id="pricing" class="container text-center">
  <h2 class="fw-bold mb-5">Pricing 💰</h2>

  <div class="row">
    <div class="col-md-4"><div class="card p-4 shadow">₹999</div></div>
    <div class="col-md-4"><div class="card p-4 shadow border-primary">₹1999</div></div>
    <div class="col-md-4"><div class="card p-4 shadow">₹4999</div></div>
  </div>
</section>

<!-- SCROLL ANIMATION -->
<script>
  const sections = document.querySelectorAll("section");

  window.addEventListener("scroll", () => {
    sections.forEach(sec => {
      const offset = sec.offsetTop - 200;

      if(window.scrollY > offset){
        sec.style.opacity = "1";
        sec.style.transform = "translateY(0)";
      }
    });
  });
</script>

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Wanderlust</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Google Font -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

  <style>
    body {
      margin: 0;
      font-family: 'Poppins', sans-serif;
    }

    /* 🌍 HERO SECTION */
    .hero {
      height: 100vh;
      background: url("https://images.unsplash.com/photo-1501785888041-af3ef285b470") center/cover no-repeat;
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    /* DARK OVERLAY */
    .hero::before {
      content: "";
      position: absolute;
      width: 100%;
      height: 100%;
      background: rgba(0,0,0,0.5);
    }

    /* 🔥 PREMIUM NAVBAR */
    .navbar-custom {
      position: absolute;
      top: 20px;
      left: 50%;
      transform: translateX(-50%);
      width: 90%;

      display: flex;
      justify-content: space-between;
      align-items: center;

      padding: 12px 25px;
      border-radius: 50px;

      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(10px);

      z-index: 10;
    }

    .navbar-custom a {
      color: white;
      text-decoration: none;
      margin: 0 12px;
      font-weight: 500;
      transition: 0.3s;
    }

    .navbar-custom a:hover {
      color: orange;
    }

    .logo {
      font-size: 22px;
      font-weight: bold;
      color: white;
    }

    .signup-btn {
      background: orange;
      padding: 6px 15px;
      border-radius: 20px;
      color: white;
      font-weight: bold;
    }

    /* HERO CONTENT */
    .hero-content {
      text-align: center;
      color: white;
      z-index: 2;
    }

    .hero-content h1 {
      font-size: 50px;
      font-weight: bold;
    }

    .explore-btn {
      background: orange;
      border: none;
      padding: 12px 30px;
      border-radius: 25px;
      margin-top: 20px;
      color: white;
      font-weight: bold;
      transition: 0.3s;
    }

    .explore-btn:hover {
      background: #ff8800;
      transform: scale(1.05);
    }

    /* SEARCH BOX */
    .search-box {
      margin-top: 30px;
      background: white;
      border-radius: 50px;
      padding: 10px;
      display: flex;
      gap: 10px;
      width: 90%;
      max-width: 600px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.3);
    }

    .search-box input {
      border: none;
      outline: none;
      flex: 1;
      padding-left: 10px;
    }

    .search-btn {
      background: #222;
      border: none;
      border-radius: 50px;
      padding: 8px 20px;
      color: white;
    }
  </style>
</head>

<body>

<!-- 🔥 NAVBAR -->
<div class="navbar-custom">

  <div class="logo">🌍 Wanderlust</div>

  <div>
    <a href="/">Home</a>
    <a href="#">Destination</a>
    <a href="#">Features</a>
    <a href="#">Pricing</a>
    <a href="#">About</a>
  </div>

  <div>
    <a href="/login">Sign in</a>
    <a href="/signup" class="signup-btn">Sign up</a>
  </div>

</div>

<!-- 🌍 HERO -->
<div class="hero">

  <div class="hero-content">

    <h1>Let’s Explore the World 🌍</h1>

    <button class="explore-btn" onclick="location.href='/listings'">
      Explore Now
    </button>

    <form action="/listings" method="GET" class="search-box">
      <input type="text" name="search" placeholder="Search destination..." />
      <button class="search-btn">Search</button>
    </form>

  </div>

</div>

</body>
</html>